---
interface Props {
  title: string;
  pubDate: Date;
  author: string;
  description: string;
  tags?: string[];
  slug: string;
}

const { title, pubDate, author, description, tags = [], slug } = Astro.props;

const formattedDate = pubDate.toLocaleDateString('en-CA', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article style="background:var(--color-surface);border:1px solid var(--color-border);border-radius:calc(var(--radius)*1.5);padding:1.5rem;display:flex;flex-direction:column;gap:0.75rem;transition:box-shadow 0.2s,transform 0.2s;" class="blog-card">
  <!-- Tags -->
  {tags.length > 0 && (
    <div style="display:flex;gap:0.4rem;flex-wrap:wrap;">
      {tags.map(tag => (
        <span style="font-size:0.7rem;font-weight:600;letter-spacing:0.05em;text-transform:uppercase;background:rgba(13,148,136,0.1);color:var(--color-teal);padding:0.2rem 0.5rem;border-radius:9999px;">
          {tag}
        </span>
      ))}
    </div>
  )}

  <!-- Title -->
  <h2 style="margin:0;font-size:1.15rem;font-weight:700;line-height:1.3;color:var(--color-teal-dark);">
    <a href={`/blog/${slug}`} style="text-decoration:none;color:inherit;" class="card-link">
      {title}
    </a>
  </h2>

  <!-- Meta -->
  <p style="margin:0;font-size:0.8rem;color:var(--color-muted);">
    <time datetime={pubDate.toISOString()}>{formattedDate}</time>
    {' · '}
    <span>{author}</span>
  </p>

  <!-- Excerpt -->
  <p style="margin:0;font-size:0.925rem;color:var(--color-text);line-height:1.65;flex:1;">
    {description}
  </p>

  <!-- Read more -->
  <a href={`/blog/${slug}`} style="align-self:flex-start;font-size:0.875rem;font-weight:600;color:var(--color-teal);text-decoration:none;">
    Read more &rarr;
  </a>
</article>

<style>
  .blog-card:hover {
    box-shadow: 0 4px 20px rgba(0,0,0,0.08);
    transform: translateY(-2px);
  }
  .card-link:hover {
    color: var(--color-teal) !important;
  }
</style>
