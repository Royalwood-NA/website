---
const year = new Date().getFullYear();
---

<footer style="background:var(--color-teal-dark);color:#e2e8f0;margin-top:auto;">
  <div style="max-width:1200px;margin:0 auto;padding:3rem 1.5rem 2rem;display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:2rem;">

    <!-- Brand -->
    <div style="grid-column:1/-1;max-width:320px;">
      <img src="/logo.svg" alt="Royalwood Neighbourhood Association" height="36" style="height:36px;width:auto;filter:brightness(0) invert(1);opacity:0.9;" />
      <p style="margin-top:0.75rem;font-size:0.875rem;color:#94a3b8;line-height:1.6;">
        Serving the Royalwood community in Edmonton, Alberta. A volunteer-run neighbourhood association.
      </p>
    </div>

    <!-- Quick Links -->
    <nav aria-label="Footer navigation — Quick Links">
      <h3 style="font-size:0.75rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:#94a3b8;margin-bottom:0.75rem;">Quick Links</h3>
      <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:0.4rem;">
        {[
          { href: '/',             label: 'Home' },
          { href: '/about',        label: 'About the RNA' },
          { href: '/events',       label: 'Events' },
          { href: '/get-involved', label: 'Get Involved' },
        ].map(l => (
          <li>
            <a href={l.href} style="color:#cbd5e1;text-decoration:none;font-size:0.9rem;transition:color 0.15s;" onmouseover="this.style.color='#2dd4bf'" onmouseout="this.style.color='#cbd5e1'">
              {l.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <!-- Content -->
    <nav aria-label="Footer navigation — Content">
      <h3 style="font-size:0.75rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:#94a3b8;margin-bottom:0.75rem;">Content</h3>
      <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:0.4rem;">
        {[
          { href: '/blog',                              label: 'Blog' },
          { href: '/resources',                         label: 'Resources' },
          { href: '/resources/bylaws-overview',         label: 'Bylaws' },
          { href: '/resources/emergency-contacts',      label: 'Emergency Contacts' },
        ].map(l => (
          <li>
            <a href={l.href} style="color:#cbd5e1;text-decoration:none;font-size:0.9rem;transition:color 0.15s;" onmouseover="this.style.color='#2dd4bf'" onmouseout="this.style.color='#cbd5e1'">
              {l.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <!-- Contact -->
    <div>
      <h3 style="font-size:0.75rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:#94a3b8;margin-bottom:0.75rem;">Contact</h3>
      <ul style="list-style:none;padding:0;margin:0;display:flex;flex-direction:column;gap:0.4rem;">
        <li>
          <a href="mailto:board@royalwoodna.org" style="color:#cbd5e1;text-decoration:none;font-size:0.9rem;">board@royalwoodna.org</a>
        </li>
        <li>
          <a href="/contact" style="color:#cbd5e1;text-decoration:none;font-size:0.9rem;">Contact Page</a>
        </li>
        <li>
          <a href="/search" style="color:#cbd5e1;text-decoration:none;font-size:0.9rem;">Search</a>
        </li>
      </ul>
    </div>

  </div>

  <div style="max-width:1200px;margin:0 auto;padding:1rem 1.5rem;border-top:1px solid rgba(255,255,255,0.1);display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:0.5rem;">
    <p style="font-size:0.8rem;color:#64748b;margin:0;">
      &copy; {year} Royalwood Neighbourhood Association. Maintained by RNA volunteers.
    </p>
    <p style="font-size:0.8rem;color:#64748b;margin:0;">
      Edmonton, Alberta, Canada
    </p>
  </div>
</footer>
