---
import BaseLayout from './BaseLayout.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, pubDate, updatedDate, author, category } = post.data;

const formattedPub = pubDate.toLocaleDateString('en-CA', {
  year: 'numeric', month: 'long', day: 'numeric',
});
const formattedUpd = updatedDate?.toLocaleDateString('en-CA', {
  year: 'numeric', month: 'long', day: 'numeric',
});
---

<BaseLayout title={title} description={description}>
  <article class="blog-post">
    <!-- Hero -->
    <div class="blog-post__hero">
      <div class="container container--narrow">
        {category && (
          <a href={`/blog?category=${encodeURIComponent(category)}`} class="badge badge--accent">
            {category}
          </a>
        )}
        <h1 class="blog-post__title">{title}</h1>
        <div class="blog-post__meta">
          <span>By <strong>{author}</strong></span>
          <span class="blog-post__meta-dot" aria-hidden="true">·</span>
          <time datetime={pubDate.toISOString()}>{formattedPub}</time>
          {updatedDate && (
            <>
              <span class="blog-post__meta-dot" aria-hidden="true">·</span>
              <span>Updated <time datetime={updatedDate.toISOString()}>{formattedUpd}</time></span>
            </>
          )}
        </div>
      </div>
    </div>

    <!-- Body -->
    <div class="blog-post__body container container--narrow">
      <div class="prose">
        <slot />
      </div>

      <div class="blog-post__back">
        <a href="/blog" class="btn btn--secondary btn--sm">← Back to News</a>
      </div>
    </div>
  </article>
</BaseLayout>

<style>
.blog-post__hero {
  background: linear-gradient(135deg, var(--color-accent-pale) 0%, var(--color-surface-alt) 100%);
  border-bottom: 1px solid var(--color-border);
  padding: var(--space-12) 0 var(--space-10);
}

.blog-post__title {
  margin-top: var(--space-4);
  margin-bottom: var(--space-4);
  color: var(--color-text);
}

.blog-post__meta {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: var(--space-2);
  color: var(--color-text-muted);
  font-size: 0.9375rem;
}

.blog-post__meta-dot { opacity: 0.4; }

.blog-post__body {
  padding-block: var(--space-12);
}

.blog-post__back {
  margin-top: var(--space-12);
  padding-top: var(--space-8);
  border-top: 1px solid var(--color-border);
}
</style>
