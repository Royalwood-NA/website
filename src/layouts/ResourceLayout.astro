---
import BaseLayout from './BaseLayout.astro';
import ResourceSidebar from '../components/ResourceSidebar.astro';
import Breadcrumb from '../components/Breadcrumb.astro';

interface Props {
  title: string;
  category: string;
  description?: string;
  slug: string;
}

const { title, category, description, slug } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <div style="max-width:1200px;margin:0 auto;padding:2.5rem 1.5rem;">
    <div style="display:flex;gap:3rem;align-items:flex-start;" class="resource-layout">
      <!-- Sidebar -->
      <ResourceSidebar currentSlug={slug} />

      <!-- Main content -->
      <div style="flex:1;min-width:0;">
        <Breadcrumb crumbs={[
          { label: 'Home', href: '/' },
          { label: 'Resources', href: '/resources' },
          { label: category },
          { label: title },
        ]} />

        <article data-pagefind-body>
          <header style="margin-bottom:2rem;padding-bottom:1.5rem;border-bottom:1px solid var(--color-border);">
            <p style="font-size:0.75rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:var(--color-teal);margin:0 0 0.5rem;">
              {category}
            </p>
            <h1 style="font-size:clamp(1.5rem,3vw,2.25rem);font-weight:800;color:var(--color-teal-dark);margin:0;line-height:1.2;">
              {title}
            </h1>
            {description && (
              <p style="margin:0.75rem 0 0;font-size:1rem;color:var(--color-muted);line-height:1.6;">
                {description}
              </p>
            )}
          </header>

          <div class="prose" style="max-width:none;">
            <slot />
          </div>
        </article>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  @media (max-width: 768px) {
    .resource-layout {
      flex-direction: column !important;
    }
    .resource-layout > aside {
      width: 100% !important;
      position: static !important;
    }
  }
</style>
