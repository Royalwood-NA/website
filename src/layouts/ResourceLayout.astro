---
import BaseLayout from './BaseLayout.astro';
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';

interface Props {
  resource: CollectionEntry<'resources'>;
}

const { resource } = Astro.props;
const { title, description, section, updatedDate } = resource.data;

// Build sidebar from all resources
const allResources = await getCollection('resources', ({ data }) => !data.draft);

// Group by section, sorted by order
const sections = allResources.reduce((acc, r) => {
  const s = r.data.section;
  if (!acc[s]) acc[s] = [];
  acc[s].push(r);
  return acc;
}, {} as Record<string, CollectionEntry<'resources'>[]>);

// Sort each section's items by order
for (const s of Object.keys(sections)) {
  sections[s].sort((a, b) => a.data.order - b.data.order);
}

// Section order
const sectionOrder = ['Bylaws & Governance', 'Resident Guides', 'Meeting Minutes', 'City Resources'];
const sortedSections = sectionOrder.filter(s => sections[s])
  .concat(Object.keys(sections).filter(s => !sectionOrder.includes(s)));

const currentSlug = resource.id.replace(/\.(md|mdx)$/, '');

const formattedUpd = updatedDate?.toLocaleDateString('en-CA', {
  year: 'numeric', month: 'long', day: 'numeric',
});
---

<BaseLayout title={title} description={description}>
  <div class="resource-layout">
    <!-- Sidebar -->
    <aside class="resource-sidebar" aria-label="Resource navigation">
      <div class="resource-sidebar__inner">
        <div class="resource-sidebar__header">
          <a href="/resources" class="resource-sidebar__back">← All Resources</a>
        </div>
        <nav>
          {sortedSections.map(sectionName => (
            <div class="sidebar-section">
              <div class="sidebar-section__heading">{sectionName}</div>
              <ul class="sidebar-section__list" role="list">
                {sections[sectionName].map(r => (
                  <li>
                    <a
                      href={`/resources/${r.id.replace(/\.(md|mdx)$/, '')}`}
                      class={`sidebar-link ${r.id.replace(/\.(md|mdx)$/, '') === currentSlug ? 'sidebar-link--active' : ''}`}
                      aria-current={r.id.replace(/\.(md|mdx)$/, '') === currentSlug ? 'page' : undefined}
                    >
                      {r.data.title}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          ))}
        </nav>
      </div>
    </aside>

    <!-- Content -->
    <article class="resource-content">
      <header class="resource-content__header">
        <div class="badge badge--accent">{section}</div>
        <h1 class="resource-content__title">{title}</h1>
        <p class="resource-content__desc">{description}</p>
        {updatedDate && (
          <p class="resource-content__updated text-subtle">
            Last updated: <time datetime={updatedDate.toISOString()}>{formattedUpd}</time>
          </p>
        )}
      </header>

      <div class="prose">
        <slot />
      </div>

      <div class="resource-content__back">
        <a href="/resources" class="btn btn--secondary btn--sm">← All Resources</a>
      </div>
    </article>
  </div>
</BaseLayout>

<style>
.resource-layout {
  display: grid;
  grid-template-columns: var(--sidebar-width) 1fr;
  min-height: calc(100vh - 4.5rem);
  max-width: var(--max-width);
  margin-inline: auto;
  padding-inline: var(--space-6);
  gap: var(--space-10);
  align-items: start;
}

/* Sidebar */
.resource-sidebar {
  position: sticky;
  top: calc(4.5rem + var(--space-8));
  max-height: calc(100vh - 6rem);
  overflow-y: auto;
  padding-block: var(--space-8);
}

.resource-sidebar__inner {
  background: var(--color-surface);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-lg);
  padding: var(--space-5);
}

.resource-sidebar__header {
  margin-bottom: var(--space-5);
  padding-bottom: var(--space-4);
  border-bottom: 1px solid var(--color-border);
}

.resource-sidebar__back {
  font-size: 0.875rem;
  font-weight: 500;
  color: var(--color-text-muted);
  text-decoration: none;
  display: flex;
  align-items: center;
  gap: var(--space-1);
  transition: color var(--transition);
}

.resource-sidebar__back:hover { color: var(--color-accent); }

.sidebar-section {
  margin-bottom: var(--space-5);
}

.sidebar-section__heading {
  font-size: 0.7rem;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--color-text-subtle);
  padding: 0 var(--space-3);
  margin-bottom: var(--space-2);
}

.sidebar-section__list {
  list-style: none;
  padding: 0;
  display: flex;
  flex-direction: column;
  gap: 1px;
}

.sidebar-link {
  display: block;
  padding: var(--space-2) var(--space-3);
  font-size: 0.875rem;
  font-weight: 500;
  color: var(--color-text-muted);
  text-decoration: none;
  border-radius: var(--radius-sm);
  transition: all var(--transition);
  line-height: 1.4;
}

.sidebar-link:hover {
  color: var(--color-accent);
  background: var(--color-accent-pale);
}

.sidebar-link--active {
  color: var(--color-accent);
  background: var(--color-accent-pale);
  font-weight: 600;
}

/* Content area */
.resource-content {
  padding-block: var(--space-10);
  min-width: 0;
}

.resource-content__header {
  margin-bottom: var(--space-8);
  padding-bottom: var(--space-6);
  border-bottom: 1px solid var(--color-border);
}

.resource-content__title {
  margin-top: var(--space-3);
  margin-bottom: var(--space-3);
}

.resource-content__desc {
  font-size: 1.0625rem;
  color: var(--color-text-muted);
  margin-bottom: var(--space-3);
}

.resource-content__updated {
  font-size: 0.8125rem;
  margin: 0;
}

.resource-content__back {
  margin-top: var(--space-12);
  padding-top: var(--space-8);
  border-top: 1px solid var(--color-border);
}

/* Mobile */
@media (max-width: 768px) {
  .resource-layout {
    grid-template-columns: 1fr;
    padding-inline: var(--space-4);
  }

  .resource-sidebar {
    position: static;
    max-height: none;
    padding-block: var(--space-6) 0;
  }

  .resource-content {
    padding-top: 0;
  }
}
</style>
