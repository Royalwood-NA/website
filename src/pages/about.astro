---
import BaseLayout from '../layouts/BaseLayout.astro';
import board from '../data/board.json';
---

<BaseLayout
  title="About"
  description="Learn about the Royalwood Neighbourhood Association — our mission, history, board members, and how we serve the community."
>
  <!-- Page header -->
  <div style="background:linear-gradient(135deg,var(--color-teal-dark),#0f766e);color:#fff;padding:3.5rem 1.5rem;">
    <div style="max-width:760px;margin:0 auto;">
      <h1 style="font-size:clamp(1.75rem,4vw,2.75rem);font-weight:800;margin:0 0 0.75rem;color:#fff;">About the RNA</h1>
      <p style="font-size:1.05rem;color:rgba(255,255,255,0.85);margin:0;line-height:1.6;">
        A little about who we are, what we do, and why it matters.
      </p>
    </div>
  </div>

  <div style="max-width:900px;margin:0 auto;padding:3rem 1.5rem;" data-pagefind-body>

    <!-- Mission -->
    <section style="margin-bottom:3.5rem;">
      <h2 style="font-size:1.5rem;font-weight:800;color:var(--color-teal-dark);margin:0 0 1rem;">Our Mission</h2>
      <div class="prose">
        <p>
          The Royalwood Neighbourhood Association exists to represent the interests of residents, foster a strong sense of community, and ensure Royalwood remains a safe, welcoming, and well-maintained place for families of all backgrounds.
        </p>
        <p>
          We work in partnership with the City of Edmonton, local schools, and community organizations to address neighbourhood concerns, celebrate what makes Royalwood special, and plan for its future. Our work is carried out entirely by volunteers who live in the neighbourhood and care deeply about it.
        </p>
      </div>
    </section>

    <!-- History -->
    <section style="margin-bottom:3.5rem;">
      <h2 style="font-size:1.5rem;font-weight:800;color:var(--color-teal-dark);margin:0 0 1rem;">Our History</h2>
      <div class="prose">
        <p>
          Royalwood was developed in the 1990s as part of Edmonton's southeastward expansion into the Millwoods area. As the neighbourhood grew and matured, residents recognized the need for a formal body to represent their interests and organize community life.
        </p>
        <p>
          The Royalwood Neighbourhood Association was formally incorporated in the early 2000s and has since grown into an active organization with a seven-member elected board and dozens of engaged volunteers. Over the years, we've advocated successfully for pathway improvements, park upgrades, traffic calming measures, and enhanced transit service.
        </p>
        <p>
          Today, the RNA continues to evolve — adapting to a neighbourhood that has grown more diverse, more connected, and more engaged than ever before.
        </p>
      </div>
    </section>

    <!-- Board -->
    <section style="margin-bottom:3.5rem;">
      <h2 style="font-size:1.5rem;font-weight:800;color:var(--color-teal-dark);margin:0 0 0.5rem;">Our Board</h2>
      <p style="color:var(--color-muted);margin:0 0 1.75rem;">Board members are elected at the Annual General Meeting for two-year terms.</p>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:1rem;">
        {board.map(member => (
          <div style="background:var(--color-surface);border:1px solid var(--color-border);border-radius:calc(var(--radius)*1.5);padding:1.25rem;text-align:center;">
            <div style="width:56px;height:56px;border-radius:50%;background:linear-gradient(135deg,var(--color-teal),var(--color-teal-dark));display:flex;align-items:center;justify-content:center;margin:0 auto 0.75rem;font-size:1.25rem;font-weight:700;color:#fff;">
              {member.name.split(' ').map((n: string) => n[0]).join('')}
            </div>
            <div style="font-weight:700;color:var(--color-teal-dark);font-size:0.95rem;">{member.name}</div>
            <div style="font-size:0.8rem;color:var(--color-muted);margin-top:0.2rem;">{member.role}</div>
          </div>
        ))}
      </div>
    </section>

    <!-- Meetings -->
    <section>
      <h2 style="font-size:1.5rem;font-weight:800;color:var(--color-teal-dark);margin:0 0 1rem;">Meetings & Decisions</h2>
      <div class="prose">
        <p>
          The RNA board meets approximately every two months. Meeting dates are announced through the website and email newsletter. All residents are welcome to attend board meetings as observers.
        </p>
        <p>
          The Annual General Meeting (AGM) is held each June and is the primary opportunity for all residents to hear from the board, ask questions, and vote on significant matters such as bylaw amendments and board elections.
        </p>
        <p>
          Approved meeting minutes are posted in the <a href="/resources/meeting-minutes">Resources section</a>. If you'd like to bring a matter to the board's attention, email <a href="mailto:board@royalwoodna.org">board@royalwoodna.org</a>.
        </p>
      </div>
    </section>

  </div>
</BaseLayout>
