---
import BaseLayout from '../layouts/BaseLayout.astro';

const pageTitle = 'Contact';
const pageDescription = 'Get in touch with the Royalwood Neighbourhood Association. We\'d love to hear from you!';

const faqs = [
  {
    question: 'How do I report a concern?',
    answer:
      'You can report a neighbourhood concern by emailing us at info@royalwoodna.org or by filling out our contact form above. Please include as much detail as possible, and we\'ll respond within 48 hours.',
  },
  {
    question: 'When are board meetings?',
    answer:
      'Our board meets monthly on the second Thursday of each month at 7:00 PM. Meetings are held virtually via Zoom. Residents are welcome to attend! Check our Events page or email us for the meeting link.',
  },
  {
    question: 'How do I join the board?',
    answer:
      'We welcome interested residents to apply! Board positions include President, Vice President, Secretary, Treasurer, and various directors. Interested? Send us an email with "Board Application" as the subject, or use our contact form to express your interest.',
  },
  {
    question: 'Is there a membership fee?',
    answer:
      'No, membership is free! However, we do accept voluntary donations to support our programs and events. All contributions help us serve the community better.',
  },
];
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <!-- Page Header -->
  <section class="header-section">
    <div class="container">
      <h1>Contact Us</h1>
      <p class="header-subtitle">We'd love to hear from you. Reach out with questions, suggestions, or to get involved!</p>
    </div>
  </section>

  <!-- Two-Column Content Section -->
  <section class="section">
    <div class="container">
      <div class="contact-grid">
        <!-- Left Column: Contact Form -->
        <div class="form-column">
          <h2>Send us a Message</h2>
          <form class="contact-form" action="https://formspree.io/f/placeholder" method="POST">
            <div class="form-group">
              <label for="name">Name <span class="required">*</span></label>
              <input
                type="text"
                id="name"
                name="name"
                required
                placeholder="Your full name"
              />
            </div>

            <div class="form-group">
              <label for="email">Email <span class="required">*</span></label>
              <input
                type="email"
                id="email"
                name="email"
                required
                placeholder="your@email.com"
              />
            </div>

            <div class="form-group">
              <label for="subject">Subject <span class="required">*</span></label>
              <select id="subject" name="subject" required>
                <option value="">Select a subject...</option>
                <option value="general">General Inquiry</option>
                <option value="concern">Report a Concern</option>
                <option value="event">Event Suggestion</option>
                <option value="board">Board Application</option>
                <option value="other">Other</option>
              </select>
            </div>

            <div class="form-group">
              <label for="message">Message <span class="required">*</span></label>
              <textarea
                id="message"
                name="message"
                required
                placeholder="Tell us what's on your mind..."
                rows="6"
              ></textarea>
            </div>

            <button type="submit" class="btn btn--primary btn--lg">Send Message</button>

            <p class="form-disclaimer">
              <strong>Note:</strong> This form uses Formspree as a placeholder. In production, submissions will be directed to <a href="mailto:info@royalwoodna.org">info@royalwoodna.org</a>. We typically respond to all inquiries within 48 hours.
            </p>
          </form>
        </div>

        <!-- Right Column: Contact Info -->
        <div class="info-column">
          <h2>Contact Information</h2>
          <div class="info-card card">
            <div class="card__body">
              <div class="info-item">
                <h4 class="info-label">Email</h4>
                <p>
                  <a href="mailto:info@royalwoodna.org">info@royalwoodna.org</a>
                </p>
              </div>

              <hr />

              <div class="info-item">
                <h4 class="info-label">Mailing Address</h4>
                <p>
                  Royalwood<br />
                  Edmonton, AB
                </p>
              </div>

              <hr />

              <div class="info-item">
                <h4 class="info-label">Office Hours</h4>
                <p>
                  Monthly board meetings<br />
                  2nd Thursday of each month<br />
                  7:00 PM (Virtual via Zoom)
                </p>
                <p class="text-muted" style="margin-top: var(--space-4); font-size: 0.9rem;">
                  Check our <a href="/events">Events page</a> for meeting links and updates.
                </p>
              </div>

              <hr />

              <div class="info-item">
                <h4 class="info-label">Response Time</h4>
                <p>
                  We aim to respond to all inquiries within <strong>48 hours</strong> during business days.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="section faq-section">
    <div class="container container--narrow">
      <h2 style="text-align: center; margin-bottom: var(--space-12);">Frequently Asked Questions</h2>

      <div class="faq-list">
        {faqs.map((faq, index) => (
          <details class="faq-item" key={index}>
            <summary class="faq-question">{faq.question}</summary>
            <div class="faq-answer">
              <p>{faq.answer}</p>
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style scoped>
  /* Header Section */
  .header-section {
    background: linear-gradient(135deg, var(--color-accent) 0%, #1B4D3A 100%);
    color: white;
    padding: var(--space-16) 0;
    text-align: center;
  }

  .header-section h1 {
    color: white;
    margin-bottom: var(--space-4);
  }

  .header-subtitle {
    font-size: 1.1rem;
    opacity: 0.95;
    max-width: 600px;
    margin: 0 auto;
  }

  /* Contact Grid */
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-12);
  }

  /* Form Styles */
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .form-group label {
    font-weight: 600;
    color: var(--color-text);
    font-size: 0.95rem;
  }

  .required {
    color: #D32F2F;
  }

  .contact-form input,
  .contact-form textarea,
  .contact-form select {
    padding: var(--space-3) var(--space-4);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    font-family: var(--font-sans);
    font-size: 1rem;
    background: var(--color-surface);
    color: var(--color-text);
    transition: all var(--transition);
  }

  .contact-form input:focus,
  .contact-form textarea:focus,
  .contact-form select:focus {
    outline: none;
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px var(--color-accent-pale);
  }

  .contact-form textarea {
    resize: vertical;
    font-family: var(--font-sans);
  }

  .form-disclaimer {
    background: var(--color-highlight-pale);
    border-left: 4px solid var(--color-highlight);
    padding: var(--space-4);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin-top: var(--space-4);
  }

  .form-disclaimer a {
    color: var(--color-accent);
    text-decoration: none;
    font-weight: 600;
  }

  .form-disclaimer a:hover {
    text-decoration: underline;
  }

  /* Info Card */
  .info-card {
    border: none;
    background: var(--color-surface-alt);
    margin-top: var(--space-6);
  }

  .info-item {
    margin-bottom: var(--space-4);
  }

  .info-item:last-child {
    margin-bottom: 0;
  }

  .info-label {
    color: var(--color-accent);
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-weight: 700;
    margin-bottom: var(--space-2);
  }

  .info-card p {
    color: var(--color-text);
    line-height: 1.6;
  }

  .info-card hr {
    margin: var(--space-6) 0;
  }

  /* FAQ Section */
  .faq-section {
    background: var(--color-surface-alt);
  }

  .faq-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .faq-item {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  .faq-question {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--space-4) var(--space-6);
    cursor: pointer;
    font-weight: 600;
    color: var(--color-text);
    user-select: none;
    transition: all var(--transition);
  }

  .faq-question:hover {
    background: var(--color-surface-alt);
    color: var(--color-accent);
  }

  .faq-question::after {
    content: '+';
    font-size: 1.5rem;
    font-weight: 400;
    transition: transform var(--transition);
    margin-left: var(--space-4);
  }

  details[open] > .faq-question {
    background: var(--color-accent-pale);
    color: var(--color-accent);
    border-bottom: 1px solid var(--color-accent);
  }

  details[open] > .faq-question::after {
    transform: rotate(45deg);
  }

  .faq-answer {
    padding: var(--space-6);
    background: var(--color-surface);
    border-top: 1px solid var(--color-border);
    animation: slideDown 200ms ease-out;
  }

  .faq-answer p {
    color: var(--color-text-muted);
    line-height: 1.7;
  }

  @keyframes slideDown {
    from {
      opacity: 0;
      transform: translateY(-10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Responsive Design */
  @media (max-width: 900px) {
    .contact-grid {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }
  }

  @media (max-width: 640px) {
    .header-section {
      padding: var(--space-12) 0;
    }

    .header-section h1 {
      font-size: 2rem;
    }

    .faq-question {
      padding: var(--space-3) var(--space-4);
    }

    .faq-answer {
      padding: var(--space-4);
    }
  }
</style>
