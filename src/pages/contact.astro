---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact"
  description="Get in touch with the Royalwood Neighbourhood Association board."
>
  <!-- Page header -->
  <div style="background:linear-gradient(135deg,var(--color-teal-dark),#0f766e);color:#fff;padding:3.5rem 1.5rem;">
    <div style="max-width:760px;margin:0 auto;">
      <h1 style="font-size:clamp(1.75rem,4vw,2.75rem);font-weight:800;margin:0 0 0.75rem;color:#fff;">Contact Us</h1>
      <p style="font-size:1.05rem;color:rgba(255,255,255,0.85);margin:0;line-height:1.6;">
        We'd love to hear from you. Here's how to reach the RNA.
      </p>
    </div>
  </div>

  <div style="max-width:900px;margin:0 auto;padding:3rem 1.5rem;" data-pagefind-body>

    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:2rem;margin-bottom:3rem;">

      <!-- General inquiries -->
      <div style="background:var(--color-surface);border:1px solid var(--color-border);border-radius:calc(var(--radius)*1.5);padding:2rem;">
        <div style="width:44px;height:44px;background:rgba(13,148,136,0.1);border-radius:var(--radius);display:flex;align-items:center;justify-content:center;margin-bottom:1rem;">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-teal)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>
          </svg>
        </div>
        <h2 style="font-size:1.1rem;font-weight:700;color:var(--color-teal-dark);margin:0 0 0.5rem;">General Inquiries</h2>
        <p style="font-size:0.875rem;color:var(--color-text);line-height:1.65;margin:0 0 1rem;">
          Questions about the RNA, the neighbourhood, or how to get involved? Email the board.
        </p>
        <a href="mailto:board@royalwoodna.org" style="color:var(--color-teal);font-weight:600;font-size:0.9rem;text-decoration:none;">
          board@royalwoodna.org
        </a>
      </div>

      <!-- Secretary / Minutes -->
      <div style="background:var(--color-surface);border:1px solid var(--color-border);border-radius:calc(var(--radius)*1.5);padding:2rem;">
        <div style="width:44px;height:44px;background:rgba(13,148,136,0.1);border-radius:var(--radius);display:flex;align-items:center;justify-content:center;margin-bottom:1rem;">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-teal)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/>
          </svg>
        </div>
        <h2 style="font-size:1.1rem;font-weight:700;color:var(--color-teal-dark);margin:0 0 0.5rem;">Records & Minutes</h2>
        <p style="font-size:0.875rem;color:var(--color-text);line-height:1.65;margin:0 0 1rem;">
          Requests for meeting minutes, historical records, or governance documents.
        </p>
        <a href="mailto:secretary@royalwoodna.org" style="color:var(--color-teal);font-weight:600;font-size:0.9rem;text-decoration:none;">
          secretary@royalwoodna.org
        </a>
      </div>

      <!-- Neighbourhood Watch -->
      <div style="background:var(--color-surface);border:1px solid var(--color-border);border-radius:calc(var(--radius)*1.5);padding:2rem;">
        <div style="width:44px;height:44px;background:rgba(13,148,136,0.1);border-radius:var(--radius);display:flex;align-items:center;justify-content:center;margin-bottom:1rem;">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-teal)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>
          </svg>
        </div>
        <h2 style="font-size:1.1rem;font-weight:700;color:var(--color-teal-dark);margin:0 0 0.5rem;">Neighbourhood Watch</h2>
        <p style="font-size:0.875rem;color:var(--color-text);line-height:1.65;margin:0 0 1rem;">
          Questions about the watch program, block captains, or reporting concerns.
        </p>
        <a href="mailto:watch@royalwoodna.org" style="color:var(--color-teal);font-weight:600;font-size:0.9rem;text-decoration:none;">
          watch@royalwoodna.org
        </a>
      </div>

      <!-- Environment -->
      <div style="background:var(--color-surface);border:1px solid var(--color-border);border-radius:calc(var(--radius)*1.5);padding:2rem;">
        <div style="width:44px;height:44px;background:rgba(13,148,136,0.1);border-radius:var(--radius);display:flex;align-items:center;justify-content:center;margin-bottom:1rem;">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-teal)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M2 22 16 8M3.46 6.54 8 2l3 6-4 4-3.54-5.46zM5 14l4.5 4.5M9 18l-4 2M14 5l5-1-1 5"/>
          </svg>
        </div>
        <h2 style="font-size:1.1rem;font-weight:700;color:var(--color-teal-dark);margin:0 0 0.5rem;">Environment Committee</h2>
        <p style="font-size:0.875rem;color:var(--color-text);line-height:1.65;margin:0 0 1rem;">
          Tree concerns, green space issues, or environmental initiatives.
        </p>
        <a href="mailto:environment@royalwoodna.org" style="color:var(--color-teal);font-weight:600;font-size:0.9rem;text-decoration:none;">
          environment@royalwoodna.org
        </a>
      </div>

    </div>

    <!-- Note -->
    <div style="background:rgba(13,148,136,0.06);border:1px solid rgba(13,148,136,0.15);border-radius:var(--radius);padding:1.25rem 1.5rem;">
      <p style="margin:0;font-size:0.875rem;color:var(--color-text);line-height:1.65;">
        <strong>Please note:</strong> The RNA is staffed entirely by volunteers. We aim to respond to all inquiries within 5–7 business days. For urgent neighbourhood matters (safety concerns, emergencies), please contact <a href="/resources/emergency-contacts" style="color:var(--color-teal);">the appropriate authorities directly</a>.
      </p>
    </div>

  </div>
</BaseLayout>
