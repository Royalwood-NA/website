---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const events = await getCollection('events', ({ data }) => !data.draft);
  return events.map((event) => ({
    params: { slug: event.id.replace(/\.(md|mdx)$/, '') },
    props: { event },
  }));
}

const { event } = Astro.props;
const { Content } = await render(event);
const {
  title,
  description,
  eventDate,
  endDate,
  location,
  address,
  category,
  registration,
} = event.data;

// Check if event is in the past
const today = new Date();
today.setHours(0, 0, 0, 0);
const eventDateOnly = new Date(eventDate);
eventDateOnly.setHours(0, 0, 0, 0);
const isPastEvent = eventDateOnly < today;

// Format date/time functions
function formatFullDateTime(date: Date) {
  return date.toLocaleDateString('en-CA', {
    weekday: 'long',
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}

function formatTime(date: Date) {
  return date.toLocaleTimeString('en-CA', {
    hour: 'numeric',
    minute: '2-digit',
    hour12: true,
  });
}

function getCategoryColor(cat: string) {
  const colors: Record<string, string> = {
    community: 'badge--accent',
    meeting: 'badge--accent',
    social: 'badge--highlight',
    cleanup: 'badge--accent',
    sport: 'badge--highlight',
    other: 'badge--neutral',
  };
  return colors[cat] || 'badge--neutral';
}

function formatCategory(cat: string) {
  return cat.charAt(0).toUpperCase() + cat.slice(1);
}
---

<BaseLayout
  title={title}
  description={description}
>
  <div class="event-detail-page">
    <!-- Back Link -->
    <div class="event-detail__back">
      <div class="container">
        <a href="/events" class="back-link">← Back to Events</a>
      </div>
    </div>

    <!-- Event Hero -->
    <section class="event-detail__hero section--lg">
      <div class="container">
        <div class="event-detail__hero-content">
          <div class="event-detail__badges">
            <span class={`badge ${getCategoryColor(category)}`}>
              {formatCategory(category)}
            </span>
            {isPastEvent && (
              <span class="badge badge--neutral">
                Past Event
              </span>
            )}
          </div>

          <h1 class="event-detail__title">
            {title}
          </h1>

          <p class="event-detail__description">
            {description}
          </p>
        </div>
      </div>
    </section>

    <!-- Event Content -->
    <section class="event-detail__content section">
      <div class="container">
        <div class="event-detail__grid">
          <!-- Main Content -->
          <main class="event-detail__main">
            {isPastEvent && (
              <div class="event-notice">
                <p class="event-notice__text">
                  <strong>ℹ️ This event has passed.</strong> Learn about what
                  happened or see upcoming events.
                </p>
                <a href="/events" class="btn btn--secondary btn--sm">
                  View upcoming events →
                </a>
              </div>
            )}

            <div class="prose">
              <Content />
            </div>
          </main>

          <!-- Sidebar -->
          <aside class="event-detail__sidebar">
            <!-- Event Details Card -->
            <div class="event-sidebar-card">
              <h3 class="event-sidebar-card__title">Event Details</h3>

              <div class="event-detail-row">
                <div class="event-detail-row__label">Date & Time</div>
                <div class="event-detail-row__value">
                  <div>{formatFullDateTime(eventDate)}</div>
                  <div>
                    {formatTime(eventDate)}
                    {endDate && (
                      <>
                        {' '}–{' '}
                        {formatTime(endDate)}
                      </>
                    )}
                  </div>
                </div>
              </div>

              <div class="event-detail-row">
                <div class="event-detail-row__label">Location</div>
                <div class="event-detail-row__value">
                  {location}
                </div>
              </div>

              {address && (
                <div class="event-detail-row">
                  <div class="event-detail-row__label">Address</div>
                  <div class="event-detail-row__value">
                    {address}
                  </div>
                </div>
              )}

              {registration && (
                <div class="event-detail-row event-detail-row--action">
                  <a
                    href={registration}
                    class="btn btn--primary btn--lg"
                  >
                    Register for Event →
                  </a>
                </div>
              )}
            </div>

            <!-- Share / CTA -->
            <div class="event-sidebar-cta">
              <p>Know someone interested in this event?</p>
              <a href="/contact" class="btn btn--secondary btn--sm">
                Share or Get Info
              </a>
            </div>
          </aside>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  /* Back Link */
  .event-detail__back {
    padding: var(--space-4) 0;
    border-bottom: 1px solid var(--color-border);
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--color-accent);
    text-decoration: none;
    transition: color var(--transition);
  }

  .back-link:hover {
    color: var(--color-accent-light);
    text-decoration: underline;
  }

  /* Hero Section */
  .event-detail__hero {
    background: linear-gradient(
      135deg,
      var(--color-accent-pale) 0%,
      var(--color-surface-alt) 100%
    );
    border-bottom: 1px solid var(--color-border);
  }

  .event-detail__hero-content {
    max-width: var(--content-width);
  }

  .event-detail__badges {
    display: flex;
    gap: var(--space-3);
    margin-bottom: var(--space-4);
    flex-wrap: wrap;
  }

  .event-detail__title {
    margin-bottom: var(--space-4);
    color: var(--color-text);
  }

  .event-detail__description {
    font-size: 1.125rem;
    color: var(--color-text-muted);
    margin: 0;
    line-height: 1.6;
  }

  /* Content Section */
  .event-detail__grid {
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: var(--space-12);
  }

  .event-detail__main {
    max-width: var(--content-width);
  }

  .event-detail__sidebar {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  /* Notice */
  .event-notice {
    padding: var(--space-6);
    background: var(--color-highlight-pale);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    margin-bottom: var(--space-8);
  }

  .event-notice__text {
    margin-bottom: var(--space-4);
    color: var(--color-text);
  }

  /* Sidebar Card */
  .event-sidebar-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
    position: sticky;
    top: var(--space-6);
  }

  .event-sidebar-card__title {
    margin: 0 0 var(--space-6) 0;
    font-size: 1.0625rem;
    color: var(--color-text);
  }

  /* Detail Rows */
  .event-detail-row {
    padding-bottom: var(--space-6);
    border-bottom: 1px solid var(--color-border);
  }

  .event-detail-row:last-child {
    padding-bottom: 0;
    border-bottom: none;
  }

  .event-detail-row--action {
    padding-top: var(--space-6);
    padding-bottom: 0;
    margin-top: var(--space-2);
  }

  .event-detail-row__label {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: var(--space-2);
  }

  .event-detail-row__value {
    font-size: 0.9375rem;
    color: var(--color-text);
    line-height: 1.6;
  }

  /* Sidebar CTA */
  .event-sidebar-cta {
    background: var(--color-accent-pale);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
    text-align: center;
  }

  .event-sidebar-cta p {
    margin-bottom: var(--space-4);
    color: var(--color-text);
    font-size: 0.9375rem;
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .event-detail__grid {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }

    .event-sidebar-card {
      position: static;
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: var(--space-6);
    }

    .event-sidebar-card__title {
      grid-column: 1 / -1;
      margin-bottom: var(--space-4);
    }

    .event-detail-row {
      padding-bottom: var(--space-4);
    }

    .event-detail-row--action {
      grid-column: 1 / -1;
      padding: var(--space-4) 0 0 0;
      border-top: 1px solid var(--color-border);
    }
  }

  @media (max-width: 640px) {
    .event-detail__hero {
      padding-block: var(--space-12);
    }

    .event-detail__title {
      font-size: 1.5rem;
    }

    .event-detail__description {
      font-size: 1rem;
    }

    .event-sidebar-card {
      grid-template-columns: 1fr;
      gap: var(--space-4);
    }

    .event-sidebar-card__title {
      margin-bottom: var(--space-3);
    }

    .event-detail-row {
      padding-bottom: var(--space-4);
    }

    .event-detail-row--action {
      padding-top: var(--space-4);
      margin-top: var(--space-4);
    }

    .event-sidebar-cta {
      padding: var(--space-4);
    }

    .event-sidebar-cta p {
      margin-bottom: var(--space-3);
      font-size: 0.875rem;
    }
  }
</style>
