---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Get Involved"
  description="Find out how to get involved with the Royalwood Neighbourhood Association — volunteer, join the board, or just show up."
>
  <!-- Page header -->
  <div style="background:linear-gradient(135deg,var(--color-teal-dark),#0f766e);color:#fff;padding:3.5rem 1.5rem;">
    <div style="max-width:760px;margin:0 auto;">
      <h1 style="font-size:clamp(1.75rem,4vw,2.75rem);font-weight:800;margin:0 0 0.75rem;color:#fff;">Get Involved</h1>
      <p style="font-size:1.05rem;color:rgba(255,255,255,0.85);margin:0;line-height:1.6;">
        Royalwood runs on volunteers. Here's how you can be part of it.
      </p>
    </div>
  </div>

  <div style="max-width:900px;margin:0 auto;padding:3rem 1.5rem;" data-pagefind-body>

    <!-- Intro -->
    <section style="margin-bottom:3rem;">
      <div class="prose">
        <p>
          The Royalwood Neighbourhood Association is entirely volunteer-run. There are no paid staff — everything from organizing events to maintaining this website is done by residents who care about the community. We're always looking for new people to get involved, whether you can spare a few hours a year or want to take on a bigger role.
        </p>
      </div>
    </section>

    <!-- Ways to get involved -->
    <section style="margin-bottom:3rem;">
      <h2 style="font-size:1.5rem;font-weight:800;color:var(--color-teal-dark);margin:0 0 1.5rem;">Ways to Help</h2>

      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:1.25rem;">
        {[
          {
            title: 'Attend a Meeting',
            icon: '🗣',
            body: 'Show up to a board meeting or the AGM. You don\'t need to be a member to attend — just come and listen, or bring something to the table.',
          },
          {
            title: 'Volunteer at Events',
            icon: '🤝',
            body: 'Help with setup, cleanup, grilling, or face painting at our BBQ, cleanup days, and other community events. Time commitment varies.',
          },
          {
            title: 'Join the Board',
            icon: '📋',
            body: 'Board positions are elected at the AGM. Two to four seats open each year. Board members meet every two months and contribute to major decisions.',
          },
          {
            title: 'Neighbourhood Watch',
            icon: '👀',
            body: 'Participate in our community watch program — just be a good neighbour, know who to call, and stay connected with your block captain.',
          },
          {
            title: 'Help with Communications',
            icon: '📢',
            body: 'Write a blog post, help with the newsletter, or assist with social media. If you have writing or design skills, we\'d love your help.',
          },
          {
            title: 'Environmental Initiatives',
            icon: '🌿',
            body: 'Join our environment committee to help with tree canopy work, composting education, and green space stewardship.',
          },
        ].map(item => (
          <div style="background:var(--color-surface);border:1px solid var(--color-border);border-radius:calc(var(--radius)*1.5);padding:1.5rem;">
            <div style="font-size:1.75rem;margin-bottom:0.75rem;" aria-hidden="true">{item.icon}</div>
            <h3 style="font-size:1rem;font-weight:700;color:var(--color-teal-dark);margin:0 0 0.5rem;">{item.title}</h3>
            <p style="font-size:0.875rem;color:var(--color-text);line-height:1.65;margin:0;">{item.body}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- CTA -->
    <section style="background:linear-gradient(135deg,rgba(13,148,136,0.08),rgba(19,78,74,0.05));border:1px solid rgba(13,148,136,0.2);border-radius:calc(var(--radius)*2);padding:2.5rem;text-align:center;">
      <h2 style="font-size:1.35rem;font-weight:800;color:var(--color-teal-dark);margin:0 0 0.75rem;">Ready to get started?</h2>
      <p style="color:var(--color-text);margin:0 auto 1.75rem;max-width:480px;line-height:1.7;font-size:0.975rem;">
        The easiest first step is just saying hello. Drop us a message and we'll connect you with the right people and opportunities.
      </p>
      <a
        href="/contact"
        style="display:inline-block;background:var(--color-teal);color:#fff;font-weight:700;font-size:0.95rem;padding:0.8rem 2rem;border-radius:var(--radius);text-decoration:none;"
      >
        Get in touch
      </a>
    </section>

  </div>
</BaseLayout>
