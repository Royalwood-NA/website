---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import BlogCard from '../components/BlogCard.astro';
import EventCard from '../components/EventCard.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
allPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const latestPosts = allPosts.slice(0, 3);

const allEvents = await getCollection('events');
const now = new Date();
allEvents.sort((a, b) => a.data.date.valueOf() - b.data.date.valueOf());
const upcomingEvents = allEvents.filter(e => e.data.date >= now).slice(0, 3);
---

<BaseLayout title="Home">
  <Hero
    headline="Your Royalwood Neighbourhood, Connected"
    tagline="Stay up to date with community news, upcoming events, and the resources you need — all in one place, maintained by your neighbours."
    primaryCta={{ label: 'Read the Blog', href: '/blog' }}
    secondaryCta={{ label: 'Explore Resources', href: '/resources' }}
  />

  <!-- Latest Blog Posts -->
  <section style="max-width:1200px;margin:0 auto;padding:4rem 1.5rem;">
    <div style="display:flex;align-items:baseline;justify-content:space-between;margin-bottom:2rem;flex-wrap:wrap;gap:0.75rem;">
      <div>
        <h2 style="font-size:1.75rem;font-weight:800;color:var(--color-teal-dark);margin:0 0 0.35rem;">Latest Updates</h2>
        <p style="margin:0;color:var(--color-muted);font-size:0.95rem;">News and announcements from the RNA board and volunteers.</p>
      </div>
      <a href="/blog" style="font-size:0.875rem;font-weight:600;color:var(--color-teal);text-decoration:none;white-space:nowrap;">
        All posts &rarr;
      </a>
    </div>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:1.5rem;">
      {latestPosts.map(post => (
        <BlogCard
          title={post.data.title}
          pubDate={post.data.pubDate}
          author={post.data.author}
          description={post.data.description}
          tags={post.data.tags}
          slug={post.id}
        />
      ))}
    </div>
  </section>

  <!-- Upcoming Events -->
  {upcomingEvents.length > 0 && (
    <section style="background:var(--color-surface);border-top:1px solid var(--color-border);border-bottom:1px solid var(--color-border);">
      <div style="max-width:1200px;margin:0 auto;padding:4rem 1.5rem;">
        <div style="display:flex;align-items:baseline;justify-content:space-between;margin-bottom:2rem;flex-wrap:wrap;gap:0.75rem;">
          <div>
            <h2 style="font-size:1.75rem;font-weight:800;color:var(--color-teal-dark);margin:0 0 0.35rem;">Upcoming Events</h2>
            <p style="margin:0;color:var(--color-muted);font-size:0.95rem;">Mark your calendar — here's what's coming up in Royalwood.</p>
          </div>
          <a href="/events" style="font-size:0.875rem;font-weight:600;color:var(--color-teal);text-decoration:none;white-space:nowrap;">
            All events &rarr;
          </a>
        </div>
        <div style="display:flex;flex-direction:column;gap:1rem;">
          {upcomingEvents.map(event => (
            <EventCard
              title={event.data.title}
              date={event.data.date}
              location={event.data.location}
              description={event.data.description}
              slug={event.id}
            />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- About strip -->
  <section style="max-width:1200px;margin:0 auto;padding:4rem 1.5rem;">
    <div style="background:linear-gradient(135deg,rgba(13,148,136,0.06) 0%,rgba(19,78,74,0.04) 100%);border:1px solid rgba(13,148,136,0.2);border-radius:calc(var(--radius)*2);padding:2.5rem;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:2rem;">
      <div style="max-width:540px;">
        <h2 style="font-size:1.5rem;font-weight:800;color:var(--color-teal-dark);margin:0 0 0.75rem;">About the Royalwood NA</h2>
        <p style="margin:0;color:var(--color-text);line-height:1.7;font-size:0.975rem;">
          The Royalwood Neighbourhood Association is a volunteer-run organization representing residents of the Royalwood community in southeast Edmonton. We advocate for our neighbourhood, organize community events, and work to keep Royalwood a great place to live for everyone.
        </p>
      </div>
      <a
        href="/about"
        style="display:inline-block;background:var(--color-teal);color:#fff;font-weight:700;font-size:0.9rem;padding:0.75rem 1.5rem;border-radius:var(--radius);text-decoration:none;white-space:nowrap;"
      >
        Learn more about us
      </a>
    </div>
  </section>
</BaseLayout>
