---
import BaseLayout from "../layouts/BaseLayout.astro";

const pageTitle = "Membership";
const pageDescription =
  "Become a member of the Royalwood Neighbourhood Association. Your membership supports community programs, events, and advocacy for all Royalwood residents.";

const benefits = [
  {
    icon: "🗳️",
    title: "Have Your Voice Heard",
    description:
      "Members can vote at general meetings and help shape the direction of the RNA—your priorities become our priorities.",
  },
  {
    icon: "🌱",
    title: "Fund What Matters",
    description:
      "Your dues directly support programs like park clean-ups, safety initiatives, and community beautification projects.",
  },
  {
    icon: "🤝",
    title: "Connect with Neighbours",
    description:
      "Build real relationships with the people who live around you through member meet-ups and volunteer opportunities.",
  },
  {
    icon: "🏛️",
    title: "Strengthen Advocacy",
    description:
      "A larger membership base gives the RNA a stronger voice when representing Royalwood to the City of Winnipeg.",
  },
];

const householdBenefits = [
  "Voting rights for neighbourhood initiatives",
  "Member newsletter & early event access",
  "Supports all RNA programs & events",
  "Strengthens neighbourhood advocacy",
];

const businessBenefits = [
  "Preferred visibility at events, in the community & online",
  "Logo placement on website and print materials",
  "Featured social media spotlight (monthly business feature)",
  "Discounted event sponsorship opportunities",
  "Recognition in the RNA newsletter (each issue)",
  "Listing in the Royalwood Business Directory (online)",
  "Priority networking opportunities at RNA events",
  "Ability to post job listings in the newsletter",
];
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <!-- Hero Section -->
  <section class="hero">
    <div class="container">
      <h1>Join the Royalwood Neighbourhood Association</h1>
      <p class="hero-lead">
        Membership is the simplest, most impactful way to invest in the
        neighbourhood you call home. For just a small annual fee, you help keep
        Royalwood vibrant, safe, and connected.
      </p>
      <a href="#join" class="btn btn--hero">Become a Member Today</a>
    </div>
  </section>

  <!-- Why Membership Matters -->
  <section class="section">
    <div class="container">
      <div class="why-text">
        <h2>Why Membership Matters</h2>
        <p>
          The Royalwood Neighbourhood Association is an entirely volunteer-run,
          non-profit organization. We don't receive ongoing government
          funding—our programs, events, and advocacy efforts are sustained by
          the generous dues paid by members like you.
        </p>
        <p>
          When you become a member, you're not just supporting an organization.
          You're investing in better parks, safer streets, stronger community
          ties, and a neighbourhood that actively represents your interests at
          City Hall.
        </p>
        <p>
          Every household that joins makes the RNA more effective. Help us reach
          every resident in Royalwood.
        </p>
      </div>
    </div>
  </section>

  <!-- Choose Your Membership Tiers -->
  <section class="section tiers-section">
    <div class="container">
      <h2 style="text-align: center; margin-bottom: var(--space-4);">
        Choose Your Membership
      </h2>
      <p
        class="tiers-subtitle"
        style="text-align: center; margin-bottom: var(--space-12); color: var(--color-text-muted);"
      >
        Whether you're an individual household or a local business, we have a
        membership tier that's right for you.
      </p>
      <div class="tiers-grid">
        <!-- Household Membership Card -->
        <div class="tier-card card">
          <div class="card__body">
            <div class="tier-label">Household</div>
            <div class="tier-price">$25</div>
            <div class="tier-price-note">per household / year</div>
            <ul class="tier-includes">
              {householdBenefits.map((benefit) => <li>{benefit}</li>)}
            </ul>
            <a href="#join" class="btn btn--primary tier-btn"
              >Join as Household</a
            >
          </div>
        </div>

        <!-- Business Membership Card — FEATURED -->
        <div class="tier-card tier-card--business card">
          <div class="tier-badge">★ Business Premium</div>
          <div class="card__body">
            <div class="tier-label business-label">Business</div>
            <div class="tier-price business-price">$100</div>
            <div class="tier-price-note">per business / year</div>
            <ul class="tier-includes">
              {businessBenefits.map((benefit) => <li>{benefit}</li>)}
            </ul>
            <a href="#join" class="btn btn--business tier-btn"
              >Join as a Business</a
            >
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Benefits Section -->
  <section class="section benefits-section">
    <div class="container">
      <h2 style="text-align: center; margin-bottom: var(--space-12);">
        What You Get as a Member
      </h2>
      <div class="benefits-grid">
        {
          benefits.map((benefit) => (
            <div class="benefit-card card">
              <div class="card__body">
                <div class="benefit-icon">{benefit.icon}</div>
                <h3>{benefit.title}</h3>
                <p>{benefit.description}</p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- CTA / Join Section -->
  <section class="section join-section" id="join">
    <div class="container container--narrow">
      <h2 style="text-align: center; margin-bottom: var(--space-4);">
        Ready to Join?
      </h2>
      <p
        style="text-align: center; margin-bottom: var(--space-10); color: var(--color-text-muted);"
      >
        Membership is open to all households and businesses within the Royalwood
        neighbourhood. Fill out the form below and we'll be in touch with
        payment instructions. It only takes a minute.
      </p>

      <form
        class="join-form"
        action="https://formspree.io/f/placeholder"
        method="POST"
      >
        <div class="form-row">
          <div class="form-group">
            <label for="first-name">First Name</label>
            <input
              type="text"
              id="first-name"
              name="first_name"
              placeholder="Jane"
              required
            />
          </div>
          <div class="form-group">
            <label for="last-name">Last Name</label>
            <input
              type="text"
              id="last-name"
              name="last_name"
              placeholder="Smith"
              required
            />
          </div>
        </div>
        <div class="form-group">
          <label for="email">Email Address</label>
          <input
            type="email"
            id="email"
            name="email"
            placeholder="jane@example.com"
            required
          />
        </div>
        <div class="form-group">
          <label for="membership-type">Membership Type</label>
          <select id="membership-type" name="membership_type" required>
            <option value="">Select a membership type...</option>
            <option value="household">Household Membership — $25/year</option>
            <option value="business">Business Membership — $100/year</option>
          </select>
        </div>
        <div class="form-group">
          <label for="address">Address (Royalwood area)</label>
          <input
            type="text"
            id="address"
            name="address"
            placeholder="123 Royalwood Dr or Business Address"
            required
          />
        </div>
        <div class="form-group">
          <label for="business-name">Business Name (if applicable)</label>
          <input
            type="text"
            id="business-name"
            name="business_name"
            placeholder="Royalwood Roofing Co."
          />
        </div>
        <div class="form-group">
          <label for="message">Anything you'd like us to know? (optional)</label
          >
          <textarea
            id="message"
            name="message"
            rows="3"
            placeholder="Areas of interest, questions, etc."></textarea>
        </div>
        <button type="submit" class="btn btn--primary btn--full"
          >Submit Membership Application</button
        >
        <p class="form-disclaimer">
          After submitting, we'll send you payment instructions within 1–2
          business days. Household dues are $20/year; Business membership is
          $100/year.
        </p>
      </form>
    </div>
  </section>
</BaseLayout>

<style scoped>
  /* Hero Section */
  .hero {
    background: linear-gradient(135deg, var(--color-accent) 0%, #1b4d3a 100%);
    color: white;
    padding: var(--space-20) 0;
    text-align: center;
  }

  .hero h1 {
    color: white;
    margin-bottom: var(--space-6);
    font-size: clamp(2rem, 6vw, 3.5rem);
  }

  .hero-lead {
    font-size: 1.25rem;
    line-height: 1.6;
    opacity: 0.95;
    max-width: 700px;
    margin: 0 auto var(--space-10);
  }

  .btn--hero {
    background: white;
    color: var(--color-accent);
    font-weight: 700;
    padding: var(--space-4) var(--space-10);
    border-radius: var(--radius-pill);
    font-size: 1.1rem;
    text-decoration: none;
    display: inline-block;
    transition: all var(--transition);
  }

  .btn--hero:hover {
    background: var(--color-accent-pale);
    transform: translateY(-2px);
    box-shadow: var(--shadow-lg);
  }

  /* Why Membership Section */
  .why-text {
    max-width: 800px;
    margin: 0 auto;
  }

  .why-text h2 {
    margin-bottom: var(--space-6);
  }

  .why-text p {
    color: var(--color-text-muted);
    line-height: 1.8;
    margin-bottom: var(--space-5);
  }

  .why-text p:last-child {
    margin-bottom: 0;
  }

  /* Membership Tiers Section */
  .tiers-section {
    background: var(--color-surface-alt);
  }

  .tiers-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-10);
  }

  .tier-card {
    position: relative;
    transition: all var(--transition);
  }

  .tier-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }

  .tier-card.card {
    display: flex;
    flex-direction: column;
  }

  .tier-card .card__body {
    text-align: center;
    padding: var(--space-8);
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }

  /* Business Premium Card */
  .tier-card--business {
    border-top: 4px solid #b8860b;
    background: linear-gradient(
      135deg,
      rgba(184, 134, 11, 0.08) 0%,
      transparent 100%
    );
  }

  .tier-badge {
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
    background: #b8860b;
    color: white;
    padding: var(--space-2) var(--space-6);
    border-radius: var(--radius-pill);
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    white-space: nowrap;
  }

  .tier-label {
    font-size: 0.875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-accent);
    margin-bottom: var(--space-2);
    margin-top: var(--space-4);
  }

  .tier-label.business-label {
    color: #b8860b;
  }

  .tier-price {
    font-size: 4rem;
    font-weight: 800;
    font-family: var(--font-serif);
    color: var(--color-accent);
    line-height: 1;
    margin-bottom: var(--space-2);
  }

  .tier-price.business-price {
    color: #b8860b;
  }

  .tier-price-note {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin-bottom: var(--space-8);
  }

  .tier-includes {
    list-style: none;
    padding: 0;
    margin: 0 0 var(--space-8);
    text-align: left;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    flex-grow: 1;
  }

  .tier-includes li {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
    color: var(--color-text);
    font-size: 0.95rem;
  }

  .tier-includes li::before {
    content: "✓";
    color: var(--color-accent);
    font-weight: 700;
    font-size: 1rem;
    flex-shrink: 0;
    margin-top: 2px;
  }

  .tier-card--business .tier-includes li::before {
    color: #b8860b;
  }

  .tier-btn {
    margin-top: auto;
    width: 100%;
    text-align: center;
    display: inline-block;
  }

  .btn--business {
    background: #b8860b;
    color: white;
    border: none;
    padding: var(--space-3) var(--space-6);
    border-radius: var(--radius-md);
    font-weight: 700;
    text-decoration: none;
    display: inline-block;
    transition: all var(--transition);
    cursor: pointer;
    font-size: 1rem;
  }

  .btn--business:hover {
    background: #9a7409;
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }

  /* Benefits Section */
  .benefits-section {
    background: var(--color-surface-alt);
  }

  .benefits-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-6);
  }

  .benefit-card .card__body {
    display: flex;
    flex-direction: column;
  }

  .benefit-icon {
    font-size: 2.5rem;
    margin-bottom: var(--space-4);
    display: inline-block;
  }

  .benefit-card h3 {
    color: var(--color-accent);
    margin-bottom: var(--space-3);
    font-size: 1.1rem;
  }

  .benefit-card p {
    color: var(--color-text-muted);
    line-height: 1.7;
    font-size: 0.95rem;
    margin: 0;
  }

  /* Join / CTA Section */
  .join-section {
    background: var(--color-accent-pale);
  }

  .join-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    background: white;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-10);
    box-shadow: var(--shadow-md);
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-6);
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .form-group label {
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--color-text);
  }

  .form-group input,
  .form-group textarea,
  .form-group select {
    padding: var(--space-3) var(--space-4);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    font-family: var(--font-sans);
    font-size: 1rem;
    color: var(--color-text);
    background: white;
    transition: all var(--transition);
    resize: vertical;
  }

  .form-group input:focus,
  .form-group textarea:focus,
  .form-group select:focus {
    outline: none;
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px rgba(45, 106, 79, 0.1);
  }

  .form-group input::placeholder,
  .form-group textarea::placeholder {
    color: var(--color-text-muted);
  }

  .form-group select {
    appearance: none;
    background-image: url("data:image/svg+xml;charset=UTF-8,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'%3e%3cpolyline points='6 9 12 15 18 9'%3e%3c/polyline%3e%3c/svg%3e");
    background-repeat: no-repeat;
    background-position: right var(--space-3) center;
    background-size: 1.5em 1.5em;
    padding-right: var(--space-10);
  }

  .btn--full {
    width: 100%;
    text-align: center;
    display: inline-block;
  }

  .form-disclaimer {
    text-align: center;
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin: 0;
  }

  /* Responsive Design */
  @media (max-width: 900px) {
    .tiers-grid {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }

    .tier-badge {
      top: var(--space-4);
      position: static;
      transform: none;
      width: fit-content;
      margin: 0 auto var(--space-4);
    }

    .benefits-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .hero {
      padding: var(--space-12) 0;
    }

    .hero h1 {
      font-size: 1.75rem;
    }

    .hero-lead {
      font-size: 1rem;
    }

    .tiers-grid {
      grid-template-columns: 1fr;
      gap: var(--space-6);
    }

    .tier-card .card__body {
      padding: var(--space-6);
    }

    .tier-price {
      font-size: 3rem;
    }

    .benefits-grid {
      grid-template-columns: 1fr;
    }

    .form-row {
      grid-template-columns: 1fr;
    }

    .join-form {
      padding: var(--space-6);
    }
  }
</style>
