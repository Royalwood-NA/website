---
import { getCollection, render } from 'astro:content';
import ResourceLayout from '../../layouts/ResourceLayout.astro';

export async function getStaticPaths() {
  const resources = await getCollection('resources', ({ data }) => !data.draft);
  return resources.map(resource => ({
    params: { slug: resource.id.replace(/\.(md|mdx)$/, '') },
    props: { resource }
  }));
}

const { resource } = Astro.props;
const { Content } = await render(resource);
---

<ResourceLayout resource={resource}>
  <Content />
</ResourceLayout>
