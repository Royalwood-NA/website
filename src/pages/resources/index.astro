---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const allResources = await getCollection('resources', ({ data }) => !data.draft);

// Group resources by section with proper ordering
const sections = [
  'Bylaws & Governance',
  'Resident Guides',
  'Meeting Minutes',
  'City Resources'
];

const sectionIcons: Record<string, string> = {
  'Bylaws & Governance': '📜',
  'Resident Guides': '🏡',
  'Meeting Minutes': '📝',
  'City Resources': '🌐'
};

const groupedResources = sections.map(section => ({
  section,
  icon: sectionIcons[section],
  resources: allResources
    .filter(r => r.data.section === section)
    .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99))
}));
---

<BaseLayout title="Resources" description="Everything you need to know about living in Royalwood.">
  <!-- Hero Section -->
  <div class="hero-section">
    <h1 class="hero-title">Resources</h1>
    <p class="hero-subtitle">Everything you need to know about living in Royalwood.</p>
  </div>

  <!-- Resource Sections Grid -->
  <div class="resources-container">
    {groupedResources.map(({ section, icon, resources }) => (
      <div class="section-card">
        <div class="section-header">
          <span class="section-icon">{icon}</span>
          <h2 class="section-title">{section}</h2>
        </div>
        
        <div class="resources-list">
          {resources.length > 0 ? (
            resources.map(resource => (
              <div class="resource-item">
                <h3 class="resource-title">
                  <a href={`/resources/${resource.id.replace(/\.(md|mdx)$/, '')}`}>
                    {resource.data.title}
                  </a>
                </h3>
                <p class="resource-description">
                  {resource.data.description}
                </p>
                {resource.data.updatedDate && (
                  <p class="resource-date">
                    Updated: {resource.data.updatedDate.toLocaleDateString('en-US', {
                      year: 'numeric',
                      month: 'long',
                      day: 'numeric'
                    })}
                  </p>
                )}
              </div>
            ))
          ) : (
            <p class="empty-state">No resources in this section yet.</p>
          )}
        </div>
      </div>
    ))}
  </div>
</BaseLayout>

<style>
  .hero-section {
    margin-bottom: var(--space-8);
    text-align: center;
    padding: var(--space-6) 0;
  }

  .hero-title {
    font-family: var(--font-serif);
    font-size: 3rem;
    font-weight: 700;
    color: var(--color-accent);
    margin-bottom: var(--space-2);
  }

  .hero-subtitle {
    font-family: var(--font-sans);
    font-size: 1.25rem;
    color: #666;
    line-height: 1.6;
  }

  .resources-container {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(500px, 1fr));
    gap: var(--space-6);
    margin-bottom: var(--space-8);
  }

  @media (max-width: 768px) {
    .resources-container {
      grid-template-columns: 1fr;
    }

    .hero-title {
      font-size: 2rem;
    }

    .hero-subtitle {
      font-size: 1rem;
    }
  }

  .section-card {
    background: #f9f9f9;
    border: 1px solid #e0e0e0;
    border-radius: var(--radius-lg);
    padding: var(--space-6);
    transition: all 0.2s ease;
  }

  .section-card:hover {
    border-color: var(--color-accent);
    box-shadow: 0 4px 12px rgba(45, 106, 79, 0.1);
  }

  .section-header {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-5);
    padding-bottom: var(--space-4);
    border-bottom: 2px solid var(--color-accent);
  }

  .section-icon {
    font-size: 2rem;
  }

  .section-title {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    color: var(--color-accent);
    margin: 0;
  }

  .resources-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .resource-item {
    padding-bottom: var(--space-4);
  }

  .resource-item:not(:last-child) {
    border-bottom: 1px solid #e0e0e0;
  }

  .resource-title {
    margin: 0 0 var(--space-2) 0;
    font-family: var(--font-sans);
    font-size: 1.1rem;
    font-weight: 600;
  }

  .resource-title a {
    color: var(--color-accent);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .resource-title a:hover {
    color: var(--color-highlight);
    text-decoration: underline;
  }

  .resource-description {
    margin: 0 0 var(--space-1) 0;
    color: #555;
    font-size: 0.95rem;
    line-height: 1.5;
  }

  .resource-date {
    margin: 0;
    color: #999;
    font-size: 0.85rem;
    font-style: italic;
  }

  .empty-state {
    color: #999;
    font-style: italic;
    margin: 0;
  }
</style>
