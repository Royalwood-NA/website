---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Search"
  description="Search the Royalwood NA website — blog posts, resources, events, and more."
>
  <!-- Page header -->
  <div style="background:linear-gradient(135deg,var(--color-teal-dark),#0f766e);color:#fff;padding:3.5rem 1.5rem;">
    <div style="max-width:760px;margin:0 auto;">
      <h1 style="font-size:clamp(1.75rem,4vw,2.75rem);font-weight:800;margin:0 0 0.75rem;color:#fff;">Search</h1>
      <p style="font-size:1.05rem;color:rgba(255,255,255,0.85);margin:0;line-height:1.6;">
        Search across blog posts, resources, and all site content.
      </p>
    </div>
  </div>

  <div style="max-width:900px;margin:0 auto;padding:3rem 1.5rem;">
    <div id="search"></div>

    <noscript>
      <p style="color:var(--color-muted);text-align:center;padding:2rem 0;">
        Search requires JavaScript to be enabled.
      </p>
    </noscript>
  </div>
</BaseLayout>

<script>
  // Pagefind UI — only available after `npm run build`
  // In development mode this will silently fail (no pagefind index exists yet)
  window.addEventListener('DOMContentLoaded', () => {
    if (typeof (window as any).PagefindUI !== 'undefined') {
      new (window as any).PagefindUI({
        element: '#search',
        showSubResults: true,
        showImages: false,
      });
    } else {
      const el = document.getElementById('search');
      if (el) {
        el.innerHTML = `
          <div style="background:var(--color-surface);border:1px solid var(--color-border);border-radius:var(--radius);padding:2rem;text-align:center;color:var(--color-muted);">
            <p style="margin:0;font-size:0.95rem;">Search index not yet built.</p>
            <p style="margin:0.5rem 0 0;font-size:0.85rem;">Run <code style="background:var(--color-border);padding:0.1rem 0.35rem;border-radius:3px;">npm run build</code> to generate the search index.</p>
          </div>
        `;
      }
    }
  });
</script>
